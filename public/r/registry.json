{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "Prime UI Registry",
  "homepage": "https://prime-ui-mu.vercel.app",
  "items": [
    {
      "name": "image",
      "type": "registry:ui",
      "title": "Image",
      "description": "Reusable image component with LQIP support, fallback states, and skeleton loading",
      "files": [
        {
          "path": "src/components/ui/image.tsx",
          "type": "registry:component",
          "target": "src/components/ui/image.tsx"
        }
      ]
    },
    {
      "name": "skeleton",
      "type": "registry:ui",
      "title": "Skeleton",
      "description": "Reusable skeleton component with shimmer animation",
      "files": [
        {
          "path": "src/components/ui/skeleton.tsx",
          "type": "registry:ui",
          "target": "components/ui/skeleton.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "--animate-shimmer": "shimmer 2s infinite"
        }
      },
      "css": {
        "@layer base": {
          "@keyframes shimmer": {
            "from": { "transform": "translateX(-100%)" },
            "to": { "transform": "translateX(100%)" }
          }
        }
      }
    }
  ]
}
